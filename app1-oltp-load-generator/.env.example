# Oracle Database Configuration for OLTP Application
# Copy this file to .env and update with your actual credentials

# Database Connection
DB_URL=jdbc:oracle:thin:@localhost:1521:ORCL
DB_USERNAME=oltp_user
DB_PASSWORD=OltpPass123!

# Connection Pool Settings
DB_POOL_MAX=100
DB_POOL_MIN=20
DB_TIMEOUT=30000
DB_IDLE_TIMEOUT=600000
DB_MAX_LIFETIME=1800000

# Application Settings
THREADS=50

# New Relic Configuration (optional)
NEW_RELIC_LICENSE_KEY=your_license_key_here
NEW_RELIC_APP_NAME=OLTP Load Generator
NEW_RELIC_LOG_LEVEL=info
NEW_RELIC_DISTRIBUTED_TRACING_ENABLED=true

# New Relic JAR location (optional - defaults to /Users/tbalanagu/Downloads/newrelic.jar)
# Only set this if your newrelic.jar is in a different location
# NEW_RELIC_JAR_PATH=/custom/path/to/newrelic.jar
